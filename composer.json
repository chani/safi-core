{
    "name": "chani/safi-core",
    "description": "Safi Microframework Core - Pure DI, HTTP Context, Middleware Pipeline & Driver Contracts",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Jean Bruenn",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.5",
        "psr/container": "^2.0",
        "psr/log": "^3.0",
        "psr/simple-cache": "^3.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0",
        "rector/rector": "^2.0",
        "vimeo/psalm": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "Safi\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Safi\\Core\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
